# Core
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/onreel
REDIS_URL=redis://localhost:6379
API_PORT=4000
WORKFLOW_POLL_INTERVAL_MS=3000

# Sui / Chain
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_CHAIN=mainnet
ENABLE_LIVE_CHAIN=true
SUI_SPONSOR_PRIVATE_KEY=suiprivkey...
SUI_GAS_PAYMENT_COIN_LIMIT=8
CHAIN_MINT_GAS_BUDGET=50000000
CHAIN_REQUIRE_USER_SIGNATURE=false
ONREEL_PACKAGE_ID=0x...
ONREEL_POLICY_OBJECT_ID=0x0

# Seal
ENABLE_LIVE_SEAL=true
SEAL_PACKAGE_ID=0x0
SEAL_SERVER_OBJECT_IDS=0x...,0x...
SEAL_THRESHOLD=2

# Walrus
ENABLE_LIVE_WALRUS=true
WALRUS_NETWORK=mainnet
WALRUS_STORAGE_EPOCHS=104
WALRUS_DELETABLE=false
WALRUS_SIGNER_PRIVATE_KEY=suiprivkey...

# Upload and media
UPLOAD_TMP_BUCKET=onreel-upload-tmp
UPLOAD_TMP_ROOT=/var/onreel/upload-tmp
MEDIA_STORAGE_ROOT=/var/onreel/media
UPLOAD_MAX_BYTES=21474836480
UPLOAD_ALLOWED_MIME=video/mp4,video/quicktime,video/webm,video/x-matroska
