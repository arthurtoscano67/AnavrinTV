# Core
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/onreel
REDIS_URL=redis://localhost:6379
API_PORT=4000
WORKFLOW_POLL_INTERVAL_MS=3000

# Sui / Seal / Walrus
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_CHAIN=mainnet
SEAL_PACKAGE_ID=0x0
SEAL_THRESHOLD=2
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Upload and media
UPLOAD_TMP_BUCKET=onreel-upload-tmp
UPLOAD_MAX_BYTES=21474836480
UPLOAD_ALLOWED_MIME=video/mp4,video/quicktime,video/webm,video/x-matroska
