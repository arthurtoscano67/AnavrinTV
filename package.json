{
  "name": "onreel-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/shared"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @onreel/web",
    "dev:admin": "npm run dev -w @onreel/admin",
    "dev:api": "npm run dev -w @onreel/api",
    "dev:workflow": "npm run dev -w @onreel/workflow",
    "dev:media": "npm run dev -w @onreel/media-worker",
    "dev:walrus": "npm run dev -w @onreel/walrus-worker",
    "dev:chain": "npm run dev -w @onreel/chain-service",
    "dev:indexer": "npm run dev -w @onreel/indexer",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f infra/db/migrations/001_core.sql"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "~5.8.2"
  }
}
